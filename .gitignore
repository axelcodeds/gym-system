# ================================
# GYM MANAGEMENT SYSTEM - .gitignore
# ================================

# llms.txt
llms-full.txt
llms-fullall.txt

# ================================
# Node.js / Angular (gym-system)
# ================================
**/node_modules/
**/npm-debug.log
**/yarn-error.log
**/.npm/
**/.yarn/

# Angular build output
**/dist/
**/tmp/
**/out-tsc/
**/bazel-out/
**/.angular/

# Angular cache
**/.sass-cache/

# Test coverage
**/coverage/
**/testem.log
**/libpeerconnection.log
**/__screenshots__/

# ================================
# Java / Spring Boot (gym-backend)
# ================================
**/target/
!**/src/main/**/target/
!**/src/test/**/target/
**/build/
!**/src/main/**/build/
!**/src/test/**/build/

# Maven
**/.mvn/wrapper/maven-wrapper.jar
*.jar
*.war
*.ear

# Gradle (if used)
**/.gradle/
**/gradle-app.setting
!gradle-wrapper.jar

# ================================
# IDE - IntelliJ IDEA
# ================================
**/.idea/
*.iws
*.iml
*.ipr

# ================================
# IDE - Eclipse / STS
# ================================
**/.apt_generated
**/.classpath
**/.factorypath
**/.project
**/.settings/
**/.springBeans
**/.sts4-cache

# ================================
# IDE - NetBeans
# ================================
**/nbproject/private/
**/nbbuild/
**/nbdist/
**/.nb-gradle/

# ================================
# IDE - VS Code
# ================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
**/.history/

# ================================
# Environment & Secrets
# ================================
**/.env
**/.env.local
**/.env.*.local
**/application-local.properties
**/application-secrets.properties
**/secrets/

# ================================
# OS Generated Files
# ================================
**/.DS_Store
**/._*
**/.Spotlight-V100
**/.Trashes
**/ehthumbs.db
**/Thumbs.db
**/desktop.ini

# ================================
# Logs
# ================================
*.log
**/logs/
*.log.*

# ================================
# Database
# ================================
*.db
*.sqlite
*.h2.db

# ================================
# Misc
# ================================
*.tmp
*.temp
*.swp
*.swo
*~
**/.cache/
**/connect.lock
**/typings/

# LLM context files (if you want to exclude)
# llms-full.txt
# llms-fullall.txt
